# Core API
APP_NAME=Attendance System API
DEBUG=true
API_PREFIX=/api

# PostgreSQL
POSTGRES_USER=attendance_user
POSTGRES_PASSWORD=change_me_to_strong_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=attendance_db

# Security
SECRET_KEY=generate_a_new_secret_key_with_32_random_characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
QR_HMAC_SECRET=generate_a_new_qr_hmac_secret_with_32_random_characters

# Attendance settings
SESSION_TTL_MINUTES=2
QR_TOKEN_TTL_SECONDS=5

# Optional hardening
USE_REDIS_NONCE_STORE=false
REDIS_URL=redis://localhost:6379/0
ENFORCE_IP_RESTRICTION=false

# CORS / Frontend (local development)
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api
